# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# --- ON-PREMISE SECURITY & DATABASE CONFIGURATION ---
# IMPORTANT: The application WILL NOT START if the JWT secret environment variables are missing.
# Generate high-entropy values using: openssl rand -base64 48

# Mandatory JWT secret key for access token signing and verification
JWT_SECRET="GENERATE_A_SECURE_RANDOM_BASE64_KEY_DO_NOT_USE_THIS_PLACEHOLDER_key_1"

# Mandatory JWT secret key for refresh token signing and verification
JWT_REFRESH_SECRET="GENERATE_A_SECURE_RANDOM_BASE64_KEY_DO_NOT_USE_THIS_PLACEHOLDER_key_2"

# Mandatory secret key for cryptographic audit log trail signing
AUDIT_SIGNING_SECRET="GENERATE_A_SECURE_RANDOM_BASE64_KEY_DO_NOT_USE_THIS_PLACEHOLDER_key_3"

# Mandatory master encryption key for envelope encryption (length >= 32 chars)
MASTER_ENCRYPTION_KEY="GENERATE_A_SECURE_RANDOM_BASE64_KEY_DO_NOT_USE_THIS_PLACEHOLDER_key_4"

# Mandatory storage encryption key for document volume encryption (length >= 32 chars)
STORAGE_ENCRYPTION_KEY="GENERATE_A_SECURE_RANDOM_BASE64_KEY_DO_NOT_USE_THIS_PLACEHOLDER_key_5"

# Database URL for PostgreSQL Drizzle ORM (Operational User: erp_app_role)
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://erp_app_role:ErpAppSecurePass2026!@localhost:5432/erp_production"

# Migration Database URL (Owner User: db_user_prod)
MIGRATION_DATABASE_URL="postgresql://db_user_prod:YOUR_SECURE_PASSWORD_HERE@localhost:5432/erp_production"

# Operational Database User and Password
APP_DB_USER="erp_app_role"
APP_DB_PASSWORD="ErpAppSecurePass2026!"
